# Copy to .env for local dev, or set these as Variables in Railway.
# For LOCAL dev you can leave everything blank — the app uses a "dev login"
# and stores data in ./data.json automatically.

# OAuth Web client id from Google Cloud Console (required in production)
GOOGLE_CLIENT_ID=

# Comma-separated list of the Gmail addresses allowed to sign in (you + spouse)
ALLOWED_EMAILS=you@gmail.com,spouse@gmail.com

# Any long random string. Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# DATABASE_URL is provided automatically by the Railway Postgres plugin.
# Leave blank locally to use the ./data.json fallback.
DATABASE_URL=

# NODE_ENV=production is set automatically by Railway.
